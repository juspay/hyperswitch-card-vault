{
  "info": {
    "_postman_id": "c4ca9eca-2446-4011-bab0-dc0813ff737e",
    "name": "Hyperswitch Card Vault - Local",
    "description": "Postman collection for testing a local Hyperswitch Card Vault instance. Default local setup serves HTTPS at `https://localhost:3001` with a self-signed certificate, so disable SSL certificate verification in Postman or trust `certs/local/tls-cert.pem`. The default development build does not enable the encrypted middleware feature; if you run with `--features middleware`, encrypt request bodies with the bundled `utils` binary first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        },
        {
          "name": "Diagnostics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/health/diagnostics",
              "host": ["{{base_url}}"],
              "path": ["health", "diagnostics"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Legacy Data API",
      "description": "Legacy card/data endpoints under `/data`. Run `Add Card` first; it stores `card_reference` for retrieve/delete requests.",
      "item": [
        {
          "name": "Add Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('stores card', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.status).to.eql('Ok');",
                  "  pm.expect(response.payload.card_reference).to.be.a('string');",
                  "  pm.collectionVariables.set('card_reference', response.payload.card_reference);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_id\": \"test-merchant\",\n  \"merchant_customer_id\": \"test-customer\",\n  \"card\": {\n    \"card_number\": \"4242424242424242\",\n    \"name_on_card\": \"John Smith\",\n    \"card_exp_month\": \"12\",\n    \"card_exp_year\": \"30\"\n  },\n  \"ttl\": 3600\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/data/add",
              "host": ["{{base_url}}"],
              "path": ["data", "add"]
            }
          },
          "response": []
        },
        {
          "name": "Retrieve Card",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_id\": \"test-merchant\",\n  \"merchant_customer_id\": \"test-customer\",\n  \"card_reference\": \"{{card_reference}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/data/retrieve",
              "host": ["{{base_url}}"],
              "path": ["data", "retrieve"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Card",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_id\": \"test-merchant\",\n  \"merchant_customer_id\": \"test-customer\",\n  \"card_reference\": \"{{card_reference}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/data/delete",
              "host": ["{{base_url}}"],
              "path": ["data", "delete"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Vault API v2",
      "description": "Generic vault APIs under `/api/v2/vault`. The add request uses `mode=upsert` so it can be rerun safely.",
      "item": [
        {
          "name": "Add Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": \"{{entity_id}}\",\n  \"vault_id\": \"{{vault_id}}\",\n  \"data\": {\n    \"card_number\": \"4242424242424242\",\n    \"name_on_card\": \"John Smith\"\n  },\n  \"ttl\": 3600\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v2/vault/add?mode=upsert",
              "host": ["{{base_url}}"],
              "path": ["api", "v2", "vault", "add"],
              "query": [
                {
                  "key": "mode",
                  "value": "upsert"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Retrieve Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": \"{{entity_id}}\",\n  \"vault_id\": \"{{vault_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v2/vault/retrieve",
              "host": ["{{base_url}}"],
              "path": ["api", "v2", "vault", "retrieve"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": \"{{entity_id}}\",\n  \"vault_id\": \"{{vault_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v2/vault/delete",
              "host": ["{{base_url}}"],
              "path": ["api", "v2", "vault", "delete"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Fingerprint API",
      "item": [
        {
          "name": "Fingerprint",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns fingerprint id', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.fingerprint_id).to.be.a('string');",
                  "  pm.collectionVariables.set('fingerprint_id', response.fingerprint_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "x-fingerprint-id",
                "value": "{{fingerprint_id}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": \"4242424242424242\",\n  \"key\": \"test_hash_key\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/data/fingerprint",
              "host": ["{{base_url}}"],
              "path": ["data", "fingerprint"]
            }
          },
          "response": []
        }
      ]
    },
    {
